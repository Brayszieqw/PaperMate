{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper-writer/checkpoint-packet.schema.json",
  "title": "paper-writer checkpoint packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checkpoint_id",
    "checkpoint_type",
    "checkpoint_level",
    "current_phase",
    "why_pause",
    "current_result_summary",
    "recommended_action",
    "alternative_actions",
    "ui_policy"
  ],
  "properties": {
    "checkpoint_id": { "type": "string", "minLength": 1 },
    "checkpoint_type": { "enum": ["entry", "route", "mutation", "review", "finalize", "recovery", "stale_state"] },
    "checkpoint_level": { "enum": ["auto_pass", "soft", "hard", "block"] },
    "current_phase": { "type": "string", "minLength": 1 },
    "why_pause": { "type": "string", "minLength": 1 },
    "current_result_summary": { "type": "string", "minLength": 1 },
    "risk_summary": { "type": ["string", "null"] },
    "recommended_action": { "type": "string", "minLength": 1 },
    "alternative_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resume_condition": { "type": ["string", "null"] },
    "ui_policy": { "const": "button_first_text_fallback" }
  }
}
